rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    match /client_uploads/{uid}/{allPaths=**} {
      allow read, write: if signedIn() && (request.auth.uid == uid || isAdmin());
    }

    match /service_assets/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
