rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /admins/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /clients/{uid} {
      allow create: if isOwner(uid);
      allow read, update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if signedIn()
        && request.resource.data.clientUid == request.auth.uid
        && request.resource.data.clientName is string
        && request.resource.data.clientEmail is string
        && request.resource.data.serviceId is string
        && request.resource.data.serviceName is string
        && request.resource.data.finalPrice is number
        && request.resource.data.advanceAmount is number
        && request.resource.data.status is string
        && request.resource.data.paymentStatus is string;

      allow read: if isAdmin() || (signedIn() && resource.data.clientUid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
